# ─────────────────────────────────────────────────────────────────────────────
# The Stylist's Brain — Environment Variables
# Copy this file:  cp .env.example .env
# Then fill in your API key below.
# ─────────────────────────────────────────────────────────────────────────────

# OpenWeatherMap (free tier — https://openweathermap.org/appid)
OWM_API_KEY=your_free_openweathermap_key_here
WEATHER_CITY=Mumbai

# Ollama (defaults to localhost — override for Docker or remote)
# OLLAMA_HOST=http://localhost:11434
