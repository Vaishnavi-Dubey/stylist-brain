"""
pipeline.py — Wardrobe intake orchestrator (rebuilt for multi-garment single-photo flow).

New architecture:
  User uploads ONE photo of themselves wearing an outfit.
  Pipeline detects ALL garments worn in that photo.
  Each garment is isolated as a clean RGBA cutout via rembg.
  Each cutout is embedded + tagged + stored in ChromaDB.

RAM strategy (MacBook Air safe):
  Phase 1 — YOLO:  load → detect person + body regions → unload  (~80 MB peak)
  Phase 2 — rembg: lazy load → extract per-region cutouts        (~200 MB peak)
  Phase 3 — CLIP:  load → embed + tag all cutouts → unload       (~340 MB peak)
  Models are NEVER loaded simultaneously.
"""

import json
import logging
import shutil
import uuid
from pathlib import Path

logger = logging.getLogger(__name__)

# In-memory job registry.  { job_id: { status, items_added, total, error } }
_jobs: dict[str, dict] = {}
MAX_JOBS = 50

WARDROBE_DIR = Path(__file__).parents[2] / "wardrobe"

_VIDEO_EXTS = {".mp4", ".mov", ".avi", ".mkv", ".m4v", ".webm"}
_IMAGE_EXTS = {".jpg", ".jpeg", ".png", ".webp", ".bmp", ".tiff"}


def run_pipeline(job_id: str, file_paths: list[Path]) -> None:
    """
    Full wardrobe intake pipeline — designed to be run in a FastAPI BackgroundTask.

    New flow per uploaded photo:
        1. Collect source images (extract video frames if needed).
        2. Detect garment regions (top/bottom/shoes/accessories) via YOLOv8n body splitting.
        3. For each region: remove background with rembg → save clean RGBA cutout.
        4. Embed + tag each cutout with CLIP + Ollama.
        5. Persist to ChromaDB + SQLite.
        Source photos are preserved (not deleted) for potential reprocessing.
    """
    job_dir      = WARDROBE_DIR / job_id
    frames_dir   = job_dir / "frames"
    cutouts_dir  = job_dir / "cutouts"    # clean RGBA garment cutouts live here

    _set(job_id, status="processing", items_added=0, total=0, error=None)

    try:
        # ── Phase 1: collect source photos ─────────────────────────────────────
        source_photos: list[Path] = []
        for path in file_paths:
            if path.suffix.lower() in _VIDEO_EXTS:
                from intake.video import extract_frames
                extracted = extract_frames(path, frames_dir)
                source_photos.extend(extracted)
                logger.info("[%s] Extracted %d frames from %s", job_id, len(extracted), path.name)
            elif path.suffix.lower() in _IMAGE_EXTS:
                source_photos.append(path)
            else:
                logger.warning("[%s] Skipping unsupported file: %s", job_id, path.name)

        if not source_photos:
            raise ValueError("No valid images found in upload.")

        _set(job_id, total=len(source_photos))
        logger.info("[%s] Phase 1 done — %d source photo(s)", job_id, len(source_photos))

        # ── Phase 2: detect garment regions + extract cutouts ──────────────────
        cutouts_dir.mkdir(parents=True, exist_ok=True)

        # (label, cutout_path) pairs to embed in Phase 3
        all_cutouts: list[tuple[str, Path]] = []

        try:
            from intake.detect import detect_garment_regions, unload_model as unload_yolo

            for photo in source_photos:
                try:
                    regions = detect_garment_regions(photo)
                    logger.info(
                        "[%s] Detected %d region(s) in %s: %s",
                        job_id,
                        len(regions),
                        photo.name,
                        [r["label"] for r in regions],
                    )
                except Exception as exc:
                    logger.warning(
                        "[%s] Detection failed for %s: %s — treating full image as top",
                        job_id, photo.name, exc,
                    )
                    # Fallback: treat entire image as one "top" region
                    from PIL import Image as _PIL
                    w, h = _PIL.open(photo).size
                    regions = [{"label": "top", "bbox": (0, 0, w, h), "source": "fallback"}]

                from intake.segment import extract_garment_cutout, remove_person_background

                # ── Run rembg ONCE on the full photo ───────────────────────
                # Cropping body regions from the pre-cleaned RGBA is far more
                # reliable than running rembg on each small crop separately.
                person_rgba = None
                try:
                    person_rgba = remove_person_background(photo)
                    logger.info("[%s] Full-photo background removal done", job_id)
                except Exception as exc:
                    logger.warning(
                        "[%s] Full-photo rembg failed (%s) — will try per-region fallback",
                        job_id, exc,
                    )

                for i, region in enumerate(regions):
                    label    = region["label"]
                    bbox     = region["bbox"]
                    stem     = f"{photo.stem}_{label}_{i}"
                    out_path = cutouts_dir / f"{stem}.png"

                    try:
                        result = extract_garment_cutout(
                            photo, bbox, out_path, person_rgba=person_rgba
                        )
                        if result:
                            all_cutouts.append((label, result))
                            logger.info("[%s] Cutout saved: %s", job_id, result.name)
                        else:
                            logger.debug(
                                "[%s] Skipped %s/%s — fill ratio too low",
                                job_id, photo.name, label,
                            )
                    except Exception as exc:
                        logger.warning(
                            "[%s] Cutout failed for %s/%s: %s — saving raw crop as fallback",
                            job_id, photo.name, label, exc,
                        )
                        # Last resort: save raw bbox crop as RGBA
                        try:
                            from PIL import Image as _PIL
                            base = person_rgba if person_rgba is not None \
                                   else _PIL.open(photo).convert("RGBA")
                            x1, y1, x2, y2 = bbox
                            crop = base.crop((x1, y1, x2, y2))
                            crop.save(str(out_path), format="PNG")
                            all_cutouts.append((label, out_path))
                        except Exception as exc2:
                            logger.error(
                                "[%s] Even fallback crop failed for %s/%s: %s",
                                job_id, photo.name, label, exc2,
                            )
        finally:
            try:
                from intake.detect import unload_model as unload_yolo
                unload_yolo()
            except Exception:
                pass

        if not all_cutouts:
            raise ValueError("No garment cutouts produced — check source photos and detection logs.")

        logger.info("[%s] Phase 2 done — %d cutout(s)", job_id, len(all_cutouts))

        # ── Phase 3: embed + tag + store (CLIP) ────────────────────────────────
        items_added = 0
        try:
            from intake.embed import embed_image, unload_model as unload_clip
            from intake.tag import classify_vibes, dominant_color_name
            from db.chroma import add_item
            from db.sqlite import get_connection

            for label, cutout_path in all_cutouts:
                try:
                    item_id   = f"item_{uuid.uuid4().hex[:8]}"
                    embedding = embed_image(cutout_path)
                    vibes     = classify_vibes(embedding, top_k=3)
                    color     = dominant_color_name(cutout_path)

                    # Map detection label to canonical category
                    category = _label_to_category(label)

                    metadata = {
                        "category":       category,
                        "dominant_color": color,
                        "vibe_tags":      json.dumps(vibes),
                        "image_path":     str(cutout_path),
                    }

                    add_item(item_id, embedding, metadata)

                    with get_connection() as conn:
                        conn.execute(
                            """INSERT OR REPLACE INTO wardrobe_items
                               (id, image_path, category, dominant_color, vibe_tags)
                               VALUES (?, ?, ?, ?, ?)""",
                            (item_id, str(cutout_path), category, color, json.dumps(vibes)),
                        )

                    items_added += 1
                    _set(job_id, items_added=items_added)
                    logger.info(
                        "[%s] ✓ %s — %s / %s / %s",
                        job_id, item_id, category, color, vibes,
                    )

                except Exception as exc:
                    logger.error("[%s] Failed to embed %s: %s", job_id, cutout_path.name, exc)

        finally:
            try:
                from intake.embed import unload_model as unload_clip
                unload_clip()
            except Exception:
                pass

        logger.info("[%s] Phase 3 done — %d item(s) stored", job_id, items_added)

    except Exception as exc:
        logger.error("[%s] Pipeline failed: %s", job_id, exc, exc_info=True)
        _set(job_id, status="failed", error=str(exc))
        return

    finally:
        # Clean up extracted video frames (large, not needed after cutouts are done)
        # Keep: source photos (in uploads/), cutouts (in cutouts/) — both needed for reprocessing
        if frames_dir.exists():
            shutil.rmtree(frames_dir, ignore_errors=True)
            logger.debug("[%s] Cleaned up video frames dir", job_id)

    _set(job_id, status="done")
    logger.info(
        "[%s] ✅ Pipeline complete — %d item(s) added to wardrobe",
        job_id, _jobs[job_id]["items_added"],
    )


def _label_to_category(label: str) -> str:
    """Map raw detection label to canonical wardrobe category."""
    _MAP = {
        "top":       "top",
        "bottom":    "bottom",
        "shoes":     "shoes",
        "bag":       "bag",
        "accessory": "accessory",
        "outerwear": "outerwear",
        "dress":     "dress",
        "fallback":  "top",
    }
    return _MAP.get(label.lower(), label)


def _set(job_id: str, **kwargs) -> None:
    """Merge kwargs into the job's status dict. Evicts old entries beyond MAX_JOBS."""
    if job_id not in _jobs:
        _jobs[job_id] = {"status": "queued", "items_added": 0, "total": 0, "error": None}
    _jobs[job_id].update(kwargs)

    # Evict oldest completed/failed jobs once cap is reached
    if len(_jobs) > MAX_JOBS:
        evictable = [k for k, v in _jobs.items() if v["status"] in ("done", "failed")]
        for k in evictable[: len(_jobs) - MAX_JOBS]:
            del _jobs[k]
